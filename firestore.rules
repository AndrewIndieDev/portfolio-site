rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Public ratings cache for the portfolio frontend.
    match /storeRatings/{documentId} {
      allow read: if true;
      allow write: if false;
    }

    // Deny all other client access by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
